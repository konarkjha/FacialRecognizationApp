+package com.rncamerakit.events
+
+import com.facebook.react.bridge.Arguments
+import com.facebook.react.bridge.WritableMap
+import com.facebook.react.uimanager.events.Event
+
+class FaceDetectedEvent(
+    surfaceId: Int,
+    viewId: Int,
+    private val faceCount: Int,
+    private val trackingId: Int,
+    private val frameWidth: Int,
+    private val frameHeight: Int,
+) : Event<FaceDetectedEvent>(surfaceId, viewId) {
+    override fun getEventName(): String = EVENT_NAME
+
+    override fun getEventData(): WritableMap =
+        Arguments.createMap().apply {
+            putInt("faceCount", faceCount)
+            putInt("trackingId", trackingId)
+            putInt("frameWidth", frameWidth)
+            putInt("frameHeight", frameHeight)
+        }
+
+    companion object {
+        const val EVENT_NAME = "topFacesDetected"
+    }
+}
